@page "{id:int}"
@model BDAlumnos.Pages.VerDetalleModel
@{
    ViewData["Title"] = "Detalles del Alumno";
}

<div class="container mt-5">
    @if (Model.AlumnoSeleccionado == null)
    {
        <div class="alert alert-danger shadow-sm rounded-4 text-center py-4">
            <i class="bi bi-exclamation-octagon display-4"></i>
            <h4 class="mt-3">Alumno no encontrado</h4>
            <p>El ID proporcionado no coincide con ningún registro en nuestra base de datos.</p>
            <a asp-page="/Consulta" class="btn btn-danger rounded-pill px-4">Volver a la lista</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-4 mb-4 overflow-hidden">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0 fw-bold">
                    <i class="bi bi-person-lines-fill me-2"></i>Expediente Académico
                </h4>
            </div>
            <div class="card-body bg-white py-4 px-4">
                <div class="row align-items-center">
                    <div class="col-auto">
                        @if (!string.IsNullOrEmpty(Model.AlumnoSeleccionado.FotoPath))
                        {
                            <img src="@Model.AlumnoSeleccionado.FotoPath" 
                                 class="rounded-circle shadow-sm border border-3 border-white" 
                                 style="width: 80px; height: 80px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center shadow-sm" 
                                 style="width: 80px; height: 80px;">
                                <i class="bi bi-mortarboard-fill fs-2"></i>
                            </div>
                        }
                    </div>

                    <div class="col">
                        <p class="text-muted small text-uppercase fw-bold mb-1">Alumno Seleccionado</p>
                        <h3 class="text-dark fw-bold mb-0">@Model.AlumnoSeleccionado.Nombre</h3>
                        <p class="text-secondary mb-0">
                            <span class="badge bg-light text-dark border me-2">ID: #@Model.AlumnoSeleccionado.Id</span>
                            <i class="bi bi-briefcase me-1"></i> @Model.AlumnoSeleccionado.Carrera
                        </p>
                    </div>

                    <div class="col-md-auto text-md-end mt-3 mt-md-0">
                        <a asp-page="/VerInfo" asp-route-id="@Model.AlumnoSeleccionado.Id" class="btn btn-info text-white rounded-pill px-4 me-2">
                            <i class="bi bi-eye-fill me-1"></i> Perfil Completo
                        </a>
                        <a asp-page="/Consulta" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="bi bi-arrow-left me-1"></i> Volver
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4 mb-4 p-3 bg-light">
            <form method="post" asp-page-handler="Asignar" class="row g-3 align-items-center">
                <div class="col-md-auto">
                    <label class="fw-bold text-secondary"><i class="bi bi-plus-circle-fill me-1"></i> Asignar nueva materia:</label>
                </div>
                <div class="col-md-6">
                    <select name="MateriaIdSeleccionada" class="form-select border-primary-subtle shadow-sm" required>
                        <option value="">-- Seleccione una materia del catálogo --</option>
                        @foreach (var m in Model.TodasLasMaterias)
                        {
                            <option value="@m.Id">@m.Nombre (@m.Creditos créditos)</option>
                        }
                    </select>
                </div>
                <div class="col-md-auto">
                    <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">
                        <i class="bi bi-plus-lg me-1"></i> Asignar
                    </button>
                </div>
            </form>
        </div>

        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-light py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-dark">
                    <i class="bi bi-book-half text-primary me-2"></i>Materias en Curso
                </h5>
                <span class="badge bg-primary rounded-pill px-3">@Model.Lista.Count Materias</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-dark text-white text-uppercase small">
                            <tr>
                                <th class="ps-4 py-3">Nombre de la Materia</th>
                                <th class="text-center">Créditos</th>
                                <th class="text-center pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Lista)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center py-2">
                                            <i class="bi bi-check2-square text-success me-3 fs-5"></i>
                                            <span class="fw-semibold text-secondary">@item.Materia.Nombre</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-2 rounded-pill">
                                            @item.Materia.Creditos pts
                                        </span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <form method="post" asp-page-handler="Quitar" 
                                              asp-route-materiaId="@item.MateriaId">
                                            <button type="submit" class="btn btn-outline-danger btn-sm px-3 rounded-pill" 
                                                    onclick="return confirm('¿Seguro que deseas dar de baja esta materia?')">
                                                <i class="bi bi-x-circle me-1"></i> Quitar
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @if (!Model.Lista.Any())
        {
            <div class="text-center py-5 bg-white shadow-sm rounded-4 mt-4 border border-dashed border-2">
                <i class="bi bi-journal-x display-4 text-muted"></i>
                <h5 class="mt-3 text-secondary">Este alumno no tiene materias inscritas.</h5>
                <p class="text-muted">Usa el selector de arriba para inscribirlo en una asignatura.</p>
            </div>
        }
    }
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.02) !important;
    }
    .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }
</style>