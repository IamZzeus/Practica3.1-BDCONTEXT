@page "{id:int}"
@model BDAlumnos.Pages.VerDetalleModel
@{
    ViewData["Title"] = "Detalles del Alumno";
}

<div class="container mt-5">
    @if (Model.AlumnoSeleccionado == null)
    {
        <div class="alert alert-danger shadow-sm rounded-4 text-center py-4">
            <i class="bi bi-exclamation-octagon display-4"></i>
            <h4 class="mt-3">Alumno no encontrado</h4>
            <p>El ID proporcionado no coincide con ningún registro en nuestra base de datos.</p>
            <a asp-page="/Consulta" class="btn btn-danger rounded-pill px-4">Volver a la lista</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-4 mb-4 overflow-hidden">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0 fw-bold">
                    <i class="bi bi-person-lines-fill me-2"></i>Expediente Académico
                </h4>
            </div>
            <div class="card-body bg-white py-4 px-4">
                <div class="row align-items-center">
                    <div class="col-auto d-none d-md-block">
                        <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 60px; height: 60px;">
                            <i class="bi bi-mortarboard-fill fs-3"></i>
                        </div>
                    </div>
                    <div class="col">
                        <p class="text-muted small text-uppercase fw-bold mb-1">Alumno Seleccionado</p>
                        <h3 class="text-dark fw-bold mb-0">@Model.AlumnoSeleccionado.Nombre</h3>
                        <p class="text-secondary mb-0">ID de registro: #@Model.AlumnoSeleccionado.Id</p>
                    </div>
                    <div class="col-md-auto text-md-end mt-3 mt-md-0">
                        <a asp-page="/Consulta" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="bi bi-arrow-left me-1"></i> Volver a la Lista
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-light py-3">
                <h5 class="mb-0 fw-bold text-dark">
                    <i class="bi bi-book-half text-primary me-2"></i>Materias Inscritas
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-dark text-white text-uppercase small">
                            <tr>
                                <th class="ps-4 py-3" style="letter-spacing: 1px;">Nombre de la Materia</th>
                                <th class="text-center py-3">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Lista)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center py-2">
                                            <i class="bi bi-check2-square text-success me-3 fs-5"></i>
                                            <span class="fw-semibold text-secondary">@item.Materia.Nombre</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill">
                                            <i class="bi bi-check-circle-fill me-1"></i> Cursando
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @if (!Model.Lista.Any())
        {
            <div class="text-center py-5 bg-white shadow-sm rounded-4 mt-4 border border-dashed border-2">
                <i class="bi bi-journal-x display-4 text-muted"></i>
                <h5 class="mt-3 text-secondary">Este alumno no tiene materias inscritas.</h5>
                <p class="text-muted">Asigna materias desde el panel de administración o SQL.</p>
            </div>
        }
    }
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.02) !important;
    }
</style>