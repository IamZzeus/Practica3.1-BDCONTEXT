@page
@model BDAlumnos.Pages.MateriasModel
@{
    ViewData["Title"] = "Catálogo de Materias";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold mb-0">
                <i class="bi bi-book-half text-primary me-2"></i>Catálogo de Materias
            </h2>
            <p class="text-muted">Listado de asignaturas disponibles en el sistema</p>
        </div>
        <a asp-page="/CrearMateria" class="btn btn-primary shadow-sm rounded-pill px-4">
            <i class="bi bi-plus-circle me-1"></i> Nueva Materia
        </a>
    </div>

    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="ps-4 py-3">Nombre de la Asignatura</th>
                            <th class="text-center py-3 pe-4">Créditos Académicos</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var materia in Model.ListaMaterias)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center py-2">
                                        <div class="bg-info-subtle text-info rounded-circle p-2 me-3">
                                            <i class="bi bi-journal-text"></i>
                                        </div>
                                        <span class="fw-bold text-dark fs-5">@materia.Nombre</span>
                                    </div>
                                </td>
                                <td class="text-center pe-4">
                                    <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle px-4 py-2 rounded-pill fs-6">
                                        <i class="bi bi-star-fill me-1"></i> @materia.Creditos puntos
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.ListaMaterias.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-archive text-muted display-1"></i>
            <p class="text-muted mt-3">No hay materias registradas aún.</p>
        </div>
    }
</div>