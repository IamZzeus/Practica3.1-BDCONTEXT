@page "{id:int}"
@model BDAlumnos.Pages.VerInfoModel
@{
    ViewData["Title"] = "Perfil del Alumno";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-primary py-4 text-center text-white position-relative">
                    <div class="mb-3">
                        @if (!string.IsNullOrEmpty(Model.AlumnoSeleccionado?.FotoPath))
                        {
                            <img src="@Model.AlumnoSeleccionado.FotoPath"
                                 class="rounded-circle shadow border border-4 border-white"
                                 style="width: 150px; height: 150px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-white text-primary rounded-circle d-inline-flex align-items-center justify-content-center shadow"
                                 style="width: 150px; height: 150px;">
                                <i class="bi bi-person-fill display-1"></i>
                            </div>
                        }
                    </div>
                    <h2 class="fw-bold mb-0">@Model.AlumnoSeleccionado?.Nombre</h2>
                    <p class="opacity-75 mb-0">Expediente Académico Digital</p>
                </div>

                <div class="card-body p-4">
                    @if (Model.AlumnoSeleccionado == null)
                    {
                        <div class="alert alert-warning text-center">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            No se encontró el alumno solicitado.
                        </div>
                    }
                    else
                    {
                        <div class="row g-4">
                            <div class="col-md-6">
                                <h5 class="text-primary border-bottom pb-2 mb-3">
                                    <i class="bi bi-person-lines-fill me-2"></i>Datos Personales
                                </h5>
                                <p class="mb-1 text-muted small text-uppercase fw-bold">Nombre Completo</p>
                                <p class="fs-5 fw-semibold mb-3 text-dark">@Model.AlumnoSeleccionado.Nombre</p>

                                <p class="mb-1 text-muted small text-uppercase fw-bold">Correo Electrónico</p>
                                <p class="mb-3"><i class="bi bi-envelope me-2 text-primary"></i>@Model.AlumnoSeleccionado.Correo</p>

                                <p class="mb-1 text-muted small text-uppercase fw-bold">Teléfono de Contacto</p>
                                <p class="mb-3"><i class="bi bi-telephone me-2 text-primary"></i>@Model.AlumnoSeleccionado.Telefono</p>
                            </div>

                            <div class="col-md-6">
                                <h5 class="text-primary border-bottom pb-2 mb-3">
                                    <i class="bi bi-mortarboard-fill me-2"></i>Académico
                                </h5>
                                <p class="mb-1 text-muted small text-uppercase fw-bold">Carrera</p>
                                <p class="mb-3"><span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 fs-6">@Model.AlumnoSeleccionado.Carrera</span></p>

                                <p class="mb-1 text-muted small text-uppercase fw-bold">Semestre Actual</p>
                                <p class="fs-5 mb-3">@Model.AlumnoSeleccionado.Semestre ° Semestre</p>

                                <p class="mb-1 text-muted small text-uppercase fw-bold">Fecha de Nacimiento</p>
                                <p class="mb-0"><i class="bi bi-calendar3 me-2 text-primary"></i>@Model.AlumnoSeleccionado.FechaNacimiento.ToString("dd 'de' MMMM 'de' yyyy")</p>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-page="/Consulta" class="btn btn-outline-secondary px-4 rounded-pill">
                                <i class="bi bi-arrow-left me-2"></i>Volver
                            </a>
                            <div class="gap-2 d-flex">
                                <a asp-page="/AlumnoDetalles" asp-route-id="@Model.AlumnoSeleccionado.Id" class="btn btn-info text-white px-4 rounded-pill">
                                    <i class="bi bi-journal-text me-2"></i>Ver Materias
                                </a>
                                <a asp-page="/EditarAlumno" asp-route-id="@Model.AlumnoSeleccionado.Id" class="btn btn-warning px-4 rounded-pill fw-bold">
                                    <i class="bi bi-pencil-square me-2"></i>Editar Perfil
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
            
            <div class="text-center mt-3 text-muted">
                <small>ID Interno: #@Model.AlumnoSeleccionado?.Id</small>
            </div>
        </div>
    </div>
</div>