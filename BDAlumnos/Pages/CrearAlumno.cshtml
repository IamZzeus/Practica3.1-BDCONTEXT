@page
@model BDAlumnos.Pages.CrearAlumnoModel
@{
    ViewData["Title"] = "Registrar Nuevo Alumno";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-person-plus-fill me-2"></i>Registrar Nuevo Alumno</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold text-dark"><i class="bi bi-person me-1"></i>Nombre Completo</label>
                            <input asp-for="Alumno.Nombre" class="form-control" placeholder="Ej. Juan Pérez" />
                            <span asp-validation-for="Alumno.Nombre" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label class="form-label fw-bold text-dark"><i class="bi bi-book me-1"></i>Carrera</label>
                                <input asp-for="Alumno.Carrera" class="form-control" placeholder="Ej. Ingeniería en Sistemas" />
                                <span asp-validation-for="Alumno.Carrera" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold text-dark"><i class="bi bi-hash me-1"></i>Semestre</label>
                                <input asp-for="Alumno.Semestre" class="form-control" type="number" min="1" max="12" value="1" />
                                <span asp-validation-for="Alumno.Semestre" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-dark"><i class="bi bi-envelope me-1"></i>Correo Electrónico</label>
                                <input asp-for="Alumno.Correo" class="form-control" type="email" placeholder="nombre@ejemplo.com" />
                                <span asp-validation-for="Alumno.Correo" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-dark"><i class="bi bi-telephone me-1"></i>Teléfono</label>
                                <input asp-for="Alumno.Telefono" class="form-control" type="tel" placeholder="10 dígitos" />
                                <span asp-validation-for="Alumno.Telefono" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-dark"><i class="bi bi-calendar-event me-1"></i>Fecha de Nacimiento</label>
                            <input asp-for="Alumno.FechaNacimiento" class="form-control" type="date" />
                            <span asp-validation-for="Alumno.FechaNacimiento" class="text-danger small"></span>
                        </div>

                        <hr class="my-4">

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm fw-bold">
                                <i class="bi bi-check-circle-fill me-2"></i>Guardar Registro
                            </button>
                            <a asp-page="/Consulta" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Regresar a la lista
                            </a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}