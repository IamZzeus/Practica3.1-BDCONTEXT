@page
@model BDAlumnos.Pages.AlumnoMateriasModel
@{
    ViewData["Title"] = "Inscripciones - Relación Alumno-Materias";
}

<div class="container mt-5">
    <div class="mb-4 text-center text-md-start">
        <h2 class="text-primary fw-bold">
            <i class="bi bi-journal-check me-2"></i>Relación Alumno - Materias
        </h2>
        <p class="text-muted">Consulta de materias inscritas por cada estudiante en el sistema.</p>
    </div>

    <div class="card shadow border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-dark text-white text-uppercase small">
                        <tr>
                            <th class="ps-4 py-3" style="letter-spacing: 1px;">Alumno</th>
                            <th class="py-3" style="letter-spacing: 1px;">Materia</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Lista)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary-subtle text-primary rounded-circle p-2 me-3 d-none d-sm-block">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <div>
                                            <span class="fw-bold text-dark">@item.Alumno.Nombre</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-2 rounded-pill fw-medium">
                                        <i class="bi bi-book-half me-1"></i> @item.Materia.Nombre
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.Lista.Any())
    {
        <div class="alert alert-light border border-2 border-dashed mt-4 text-center py-5">
            <i class="bi bi-clipboard-x display-4 text-muted"></i>
            <p class="mt-3 text-secondary lead">No se encontraron inscripciones registradas.</p>
        </div>
    }
</div>

<style>
    /* Efecto de resaltado al pasar el ratón */
    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.03);
        transition: background-color 0.2s ease;
    }
</style>